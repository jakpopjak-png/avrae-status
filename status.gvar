embed -title "❖ ᴄʜᴀʀᴀᴄᴛᴇʀ sᴛᴀᴛᴜs ❖" -color #b19cd9 -thumb "{{image}}" {{c=character()}}{{lvl=c.levels.total_level}}{{pb=c.stats.prof_bonus}}{{mod=max([c.stats.get_mod('intelligence'), c.stats.get_mod('wisdom'), c.stats.get_mod('charisma')])}}{{req=[0,3,8,15,24,35,48,63,80,99,120,143,170,197,226,257,290,325,362,401,999][lvl] if lvl<21 else 999}}{{ms=c.get_cc('Milestone') if c.cc_exists('Milestone') else 0}} -desc "**{{name}}** | Level {{lvl}}
{{'**[ ⋆ ʟᴇᴠᴇʟ ᴜᴘ ᴀᴠᴀɪʟᴀʙʟᴇ! ⋆ ]**' if ms>=req else ''}}" -f "❖ ᴄᴏᴍʙᴀᴛ & ᴅᴇғᴇɴsᴇs ❖|**AC:** {{c.ac}}  |  **HP:** {{c.hp}}/{{c.max_hp}}
**Initiative:** {{'%+d'%c.stats.get_mod('dexterity')}}  |  **Speed:** 30 ft.  |  **PB:** {{'%+d'%pb}}" {{out=[]}}{{tr=['Bardic Inspiration','Luck Points','Heroic Inspiration','Hit Dice','Milestone','Work Week']}}{{_=[out.append(f"**⟡ {k}**\n{c.get_cc(k)} / {req}") if k=='Milestone' else out.append(f"**⟡ {k}**\n{c.get_cc(k)}") if k=='Work Week' else out.append(f"**⟡ {k}**\n"+(f"{c.get_cc(k)} / {c.get_cc_max(k)}" if c.get_cc_max(k)>0 else str(c.get_cc(k)))) if k=='Hit Dice' else out.append(f"**⟡ {k}**\n"+('✦'*c.get_cc(k)+'✧'*(c.get_cc_max(k)-c.get_cc(k)) if 0<c.get_cc_max(k)<=6 else (f"{c.get_cc(k)} / {c.get_cc_max(k)}" if c.get_cc_max(k)>6 else str(c.get_cc(k))))) for k in tr if c.cc_exists(k)]}}{{_=[out.append(f"**⟡ {cc.name}**\n"+('✦'*c.get_cc(cc.name)+'✧'*(c.get_cc_max(cc.name)-c.get_cc(cc.name)) if 0<c.get_cc_max(cc.name)<=6 else (f"{c.get_cc(cc.name)} / {c.get_cc_max(cc.name)}" if c.get_cc_max(cc.name)>6 else str(c.get_cc(cc.name))))) for cc in c.consumables if cc.name not in tr and cc.name.lower() != 'workweek']}}{{n_cc=len(out)}}{{cz_cc=(n_cc//3)+(1 if n_cc%3>0 else 0) if n_cc>0 else 1}}{{sc_cc=[out[i:i+cz_cc] for i in range(0,n_cc,cz_cc)] if n_cc>0 else []}}{{cc_f=[]}}{{_=[cc_f.append('-f "_ _|'+('\n\n'.join(chunk))+'|inline"') for i,chunk in enumerate(sc_cc)]}}{{cc_text=' '.join(cc_f)}}{{sb=[s.name for s in c.spellbook.spells if s.prepared]}}{{has_spells=len(sb)>0}}{{n=len(sb)}}{{rz=(n//2)+(1 if n%2>0 else 0) if n>0 else 1}}{{cz=15 if rz>15 else rz}}{{sc=[sb[i:i+cz] for i in range(0,n,cz)] if n>0 else []}}{{sp_f=[]}}{{_=[sp_f.append('-f "'+('❖ ᴋɴᴏᴡɴ sᴘᴇʟʟs' if i==0 else '_ _')+'|'+('\n'.join(['⋆ '+name for name in chunk]))+'|inline"') for i,chunk in enumerate(sc)] if has_spells else []}}{{sl=[f"**L{i}:** "+'✦'*c.spellbook.get_slots(i)+'✧'*(c.spellbook.get_max_slots(i)-c.spellbook.get_slots(i)) for i in range(1, 10) if c.spellbook.get_max_slots(i)>0]}}{{magic_text=f'-f "_ _|_ _" -f "❖ ᴍᴀɢɪᴄ & sʟᴏᴛs ❖|**DC:** {8+pb+mod}  |  **Atk:** {pb+mod:+d}\n'+ ('\n'.join(sl) if sl else '*No Spell Slots*') + '|inline" ' + ' '.join(sp_f) if has_spells else ''}}{{at=c.get_cvar('attune')}}{{at_text=f'-f "❖ ᴀᴛᴛᴜɴᴇᴍᴇɴᴛ|{at}"' if at else ''}} {{cc_text}} {{at_text}} {{magic_text}} -footer "💡 โชว์ไอเทม: !cvar attune ชื่อของ1, ชื่อของ2 | ดึงข้อมูลชีทใหม่: !update"
